<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp"
            android:text="Answer/End calls"
            android:textColor="@color/oneplus_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_vibrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Vibrate when calls are answered/ended"
            android:textColor="@color/oneplus_text_primary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_auto_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Auto-answer calls when connected to external audio device"
            android:textColor="@color/oneplus_text_primary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_swipe_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Swipe up to answer"
            android:textColor="@color/oneplus_text_primary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_power_end"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Press power button to end calls"
            android:textColor="@color/oneplus_text_primary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_speaker_default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="Calls default to speaker"
            android:textColor="@color/oneplus_text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:text="Reply with SMS"
            android:textColor="@color/oneplus_text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true" />

        <LinearLayout
            android:id="@+id/layout_sms_templates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="I'll call you back later."
                android:textColor="@color/oneplus_text_primary" />
            
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Can't talk now. I'm in the class, can't talk now."
                android:textColor="@color/oneplus_text_primary" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="Call me back later."
                android:textColor="@color/oneplus_text_primary" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:text="I'll be there soon."
                android:textColor="@color/oneplus_text_primary" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
