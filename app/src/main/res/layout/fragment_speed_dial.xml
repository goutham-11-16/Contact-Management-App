<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp"
            android:text="Speed dial"
            android:textColor="@color/oneplus_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="Long press a number on the dial pad to call the assigned contact."
            android:textColor="@color/oneplus_text_secondary"
            android:textSize="14sp" />

        <!-- Speed Dial Items 1-9 -->
        <include android:id="@+id/sd_1" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_2" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_3" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_4" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_5" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_6" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_7" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_8" layout="@layout/item_speed_dial_row" />
        <include android:id="@+id/sd_9" layout="@layout/item_speed_dial_row" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
